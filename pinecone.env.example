# Copy this file to `.env` in the project root or `System/` directory.
# The app will auto-load `.env` or `pinecone.env` from those locations.

PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=ci-evidence-index
PINECONE_NAMESPACE=module31
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_DIMENSION=384
PINECONE_METRIC=cosine

# Optional: if you already know the data-plane host, set it to skip describe/poll
# PINECONE_INDEX_HOST=your-index-host.svc.xxx.pinecone.io
